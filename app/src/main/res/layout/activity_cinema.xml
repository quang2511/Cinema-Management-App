<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarCinema"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:title="Hệ thống rạp"
        app:titleTextColor="#000000" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCinemas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/toolbarCinema"
        android:layout_above="@+id/bottomNavBar"
        android:paddingTop="8dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:weightSum="3">

        <TextView android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="🎟️\nChọn phim" android:textColor="#888888" android:gravity="center" android:textSize="12sp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true"/>

        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="🏢\nChọn rạp" android:textColor="#D32F2F" android:textStyle="bold" android:gravity="center" android:textSize="12sp"/>

        <TextView android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="👤\nTôi" android:textColor="#888888" android:gravity="center" android:textSize="12sp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_above="@+id/bottomNavBar" android:background="#EEEEEE"/>
</RelativeLayout>